---
import CtaBand from "../components/CtaBand.astro";
import InfoCard from "../components/InfoCard.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import { activities, activityRhythm } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Activities | YYZU"
  description="Aktivitas YYZU: study group, technical discussion, mini project, team collaboration, engineering simulation, workshop, dan learning logs."
>
  <PageHero
    eyebrow="Activities"
    title="Aktivitas YYZU menghubungkan belajar programming dengan praktik engineering nyata."
    description="Setiap aktivitas diarahkan agar learner tidak hanya menerima materi, tetapi ikut membaca konteks, mencoba, berdiskusi, membangun, menerima feedback, deploy, dan mencatat pembelajaran."
    note="Ritme aktivitas mencakup study group, technical discussion, mentoring, mini project, team project, workshop, engineering simulation, dan open-source contribution."
  />

  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <Section
        eyebrow="Activity Types"
        title="Ruang belajar yang dekat dengan teamwork engineering dan project nyata."
        description="Aktivitas dibuat agar peserta terbiasa dengan project collaboration, dokumentasi, review, delivery, dan refleksi yang relevan dengan software engineering modern."
        align="center"
      />
      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {activities.map((item) => <InfoCard {...item} />)}
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-16 text-white sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <Section
        eyebrow="Working Rhythm"
        title="Plan, build, reflect."
        description="YYZU menggunakan ritme yang mudah diikuti, tetapi cukup serius untuk membentuk kebiasaan engineering dan kesiapan industri."
        align="center"
        tone="dark"
      />
      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        {
          activityRhythm.map((item, index) => (
            <article class="rounded-lg border border-white/12 bg-white/[0.06] p-7">
              <span class="flex size-10 items-center justify-center rounded-lg bg-white text-sm font-black text-[#0015A5]">
                {index + 1}
              </span>
              <h3 class="mt-5 text-xl font-bold text-white">{item.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-300">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    title="Aktivitas YYZU adalah ruang latihan untuk tumbuh lewat real practice."
    description="Kamu bisa mulai sebagai learner, builder, dokumentator, fasilitator diskusi, mentor, atau contributor di project internal."
    primaryLabel="Join Sebagai Builder"
    primaryHref="/join/"
    secondaryLabel="Lihat Build Logs"
    secondaryHref="/projects/"
  />
</BaseLayout>
