---
import CtaBand from "../components/CtaBand.astro";
import InfoCard from "../components/InfoCard.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import { buildLogs, projectPrinciples } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Projects & Build Logs | YYZU"
  description="Projects dan build logs YYZU: collaborative projects, learning projects, workflow logs, progress updates, dan contribution stories."
>
  <PageHero
    eyebrow="Projects / Build Logs"
    title="Project YYZU menjadi ruang praktik untuk belajar, build, collaborate, dan grow."
    description="Halaman ini mencatat collaborative projects, learning projects, workflow logs, progress updates, dan contribution stories yang menunjukkan proses kerja secara transparan."
    note="Build logs membantu menjelaskan konteks, keputusan, proses review, pembelajaran, dan peran tiap kontribusi."
    tone="dark"
  />

  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <Section
        eyebrow="Current Logs"
        title="Workflow logs dan cerita kontribusi."
        description="Catatan ini dibuat agar proses belajar, project collaboration, keputusan teknis, product thinking, dan kontribusi YYZU bisa dipahami dengan jelas."
        align="center"
      />
      <div class="mt-12 grid gap-5 lg:grid-cols-2">
        {
          buildLogs.map((log) => (
            <article class="rounded-lg border border-slate-200 bg-slate-50 p-7">
              <div class="flex flex-wrap items-center gap-3">
                <span class="rounded-full bg-white px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] text-[#006A67] ring-1 ring-slate-200">
                  {log.period}
                </span>
                <span class="rounded-full bg-slate-950 px-3 py-1 text-xs font-bold text-white">
                  {log.status}
                </span>
              </div>
              <h2 class="mt-5 text-xl font-bold text-slate-950">
                {log.title}
              </h2>
              <p class="mt-4 text-sm leading-7 text-slate-600">
                {log.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-[#f7f9fb] py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <Section
        eyebrow="Project Principles"
        title="Project harus realistis, nyata, reviewable, dan bisa dipelajari."
        description="Yang penting project membantu orang belajar workflow, ownership, komunikasi, product thinking, software quality, dan kualitas kontribusi."
        align="center"
      />
      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        {projectPrinciples.map((item) => <InfoCard {...item} />)}
      </div>
    </div>
  </section>

  <CtaBand
    title="Build logs menjadi bukti proses belajar, kolaborasi, dan growth di YYZU."
    description="Jika kamu ingin membantu menulis, membangun, mendokumentasikan, mendesain, atau mengelola project, ada ruang untuk kontribusi yang jelas."
    primaryLabel="Ikut Kontribusi"
    primaryHref="/join/"
  />
</BaseLayout>
