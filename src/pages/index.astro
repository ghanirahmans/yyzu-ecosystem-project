---
import CtaBand from "../components/CtaBand.astro";
import InfoCard from "../components/InfoCard.astro";
import Section from "../components/Section.astro";
import {
  activities,
  bridgeCards,
  currentFocus,
  ecosystemRoles,
  modelSteps,
  whyYYZU,
} from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="YYZU | Engineering Ecosystem & Talent Bridge"
  description="YYZU adalah engineering ecosystem dan talent bridge untuk pengembangan talenta IT melalui collaborative learning, project collaboration, mentoring teknologi, dan pengalaman engineering nyata."
>
  <section class="relative isolate overflow-hidden bg-slate-950 text-white">
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(0,21,165,0.9)_0%,rgba(0,106,103,0.78)_48%,rgba(15,23,42,0.96)_100%)]"></div>
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.11)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.11)_1px,transparent_1px)] bg-[size:42px_42px] opacity-20"></div>
    <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 sm:py-20 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <div class="mb-8 flex size-18 items-center justify-center rounded-lg bg-white shadow-2xl shadow-slate-950/25 ring-1 ring-white/30">
            <img
              src="/yyz-project-logo_ft.svg"
              alt="Logo YYZU"
              width="52"
              height="52"
              decoding="async"
            />
          </div>
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-teal-100">
            Engineering Ecosystem & Talent Bridge
          </p>
          <h1 class="mt-5 text-4xl font-black tracking-tight text-white sm:text-6xl lg:text-7xl">
            YYZU
          </h1>
          <p class="mt-6 max-w-3xl text-xl font-semibold leading-8 text-white sm:text-2xl sm:leading-10">
            Engineering ecosystem untuk talenta teknologi belajar, membangun,
            dan tumbuh menuju kesiapan industri.
          </p>
          <p class="mt-5 max-w-3xl text-base leading-8 text-slate-200 sm:text-lg">
            YYZU menjembatani campus learning, self-learning, dan real-world
            engineering practice melalui collaborative learning, project
            collaboration, teamwork engineering, mentoring teknologi, simulasi
            workflow industri, dan kontribusi nyata.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/join/"
              class="inline-flex min-h-12 items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-bold text-[#0015A5] shadow-lg shadow-slate-950/20 transition hover:bg-slate-100"
            >
              Join & Grow Together
            </a>
            <a
              href="/about/"
              class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/30 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/10"
            >
              Pahami Ekosistem
            </a>
          </div>
        </div>

        <div class="rounded-lg border border-white/12 bg-white/[0.06] p-6 shadow-2xl shadow-slate-950/20 backdrop-blur">
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-teal-100">
            Growth Model
          </p>
          <h2 class="mt-4 text-2xl font-bold tracking-tight text-white">
            Learn, build, collaborate, contribute, grow.
          </h2>
          <p class="mt-4 text-sm leading-7 text-slate-300">
            Model pertumbuhan YYZU membantu learner bergerak dari belajar
            programming dan software engineering menuju pengalaman engineering
            yang lebih kolaboratif, praktis, dan industry-oriented.
          </p>
          <div class="mt-6 grid gap-3 sm:grid-cols-5 lg:grid-cols-1 xl:grid-cols-5">
            {
              modelSteps.map((step, index) => (
                <div class="rounded-lg border border-white/12 bg-slate-950/30 px-4 py-3">
                  <span class="text-xs font-bold text-teal-100">
                    0{index + 1}
                  </span>
                  <p class="mt-1 text-sm font-bold text-white">{step}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto grid max-w-7xl gap-10 px-5 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
      <Section
        eyebrow="Positioning"
        title="YYZU adalah engineering ecosystem, collaborative growth environment, dan talent bridge."
        description="YYZU bukan bootcamp atau seminar organization. YYZU adalah environment untuk membiasakan talenta teknologi dengan cara kerja engineering: memahami masalah, membangun solusi, bekerja dalam tim, menerima review, dan ikut bertanggung jawab pada hasil."
      />
      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
        {
          currentFocus.map((item) => (
            <article class="rounded-lg border border-slate-200 bg-slate-50 p-5">
              <h3 class="font-bold text-slate-950">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-[#f7f9fb] py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <Section
        eyebrow="Why YYZU Exists"
        title="Ada gap antara belajar teknologi dan siap ikut project nyata."
        description="Banyak orang bisa belajar syntax dan tools, tetapi belum terbiasa dengan komunikasi tim, ownership, code review, dokumentasi, prioritas, deployment, dan proses delivery. Di gap itulah YYZU dibangun sebagai jembatan pengembangan engineer."
        align="center"
      />
      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        {whyYYZU.map((item) => <InfoCard {...item} />)}
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-16 text-white sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <Section
        eyebrow="Bridge Model"
        title="Dari learning menuju real engineering experience."
        description="YYZU menempatkan dirinya sebagai jembatan praktis, bukan shortcut. Growth dibangun lewat proses collaborative learning, project-based development, dan engineering workflow yang dilatih bersama."
        align="center"
        tone="dark"
      />
      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        {
          bridgeCards.map((item) => (
            <article class="rounded-lg border border-white/12 bg-white/[0.06] p-7">
              <h3 class="text-xl font-bold text-white">{item.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-300">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
        <Section
          eyebrow="Activities Preview"
          title="Belajar lewat study group, technical discussion, mentoring, dan collaborative project."
          description="Aktivitas YYZU dirancang untuk membangun kebiasaan engineering secara bertahap. Bukan event ramai sesaat, tetapi proses yang bisa diulang dan ditingkatkan."
        />
        <div class="grid gap-4 sm:grid-cols-2">
          {
            activities.slice(0, 4).map((activity) => (
              <article class="rounded-lg border border-slate-200 bg-slate-50 p-5">
                <h3 class="font-bold text-slate-950">{activity.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">
                  {activity.description}
                </p>
              </article>
            ))
          }
        </div>
      </div>
      <div class="mt-8">
        <a
          href="/activities/"
          class="inline-flex min-h-12 items-center justify-center rounded-full border border-slate-300 px-6 py-3 text-sm font-bold text-slate-800 transition hover:border-[#0015A5] hover:text-[#0015A5]"
        >
          Lihat Aktivitas
        </a>
      </div>
    </div>
  </section>

  <section class="bg-[#f7f9fb] py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <Section
        eyebrow="Ecosystem"
        title="Ekosistem untuk learner, campus, community, mentor, dan partner industri."
        description="YYZU menghubungkan orang dan institusi yang ingin memperkuat pengembangan talenta IT melalui kultur engineering, project nyata, mentoring, dan kontribusi konsisten."
        align="center"
      />
      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        {ecosystemRoles.map((role) => <InfoCard {...role} />)}
      </div>
    </div>
  </section>

  <CtaBand
    title="Kalau kamu ingin tumbuh sebagai future engineer, YYZU adalah tempat untuk belajar dengan cara membangun."
    description="Join YYZU untuk berkembang lewat kolaborasi, project-based learning, engineering workflow, dan kontribusi yang bisa dipertanggungjawabkan."
    primaryLabel="Join YYZU"
    primaryHref="/join/"
    secondaryLabel="Pelajari Culture"
    secondaryHref="/culture/"
  />
</BaseLayout>
