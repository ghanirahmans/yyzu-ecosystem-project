---
import CtaBand from "../components/CtaBand.astro";
import InfoCard from "../components/InfoCard.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import { bridgeCards, visionMission, whyYYZU } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About YYZU | Engineering Ecosystem"
  description="Tentang YYZU sebagai engineering ecosystem, talent bridge, dan ruang pengembangan talenta IT menuju pengalaman engineering nyata dan kesiapan industri."
>
  <PageHero
    eyebrow="About YYZU"
    title="YYZU dibuat untuk menjembatani learning dan real engineering practice."
    description="Banyak talenta teknologi belajar dengan serius, tetapi belum punya ruang yang cukup untuk merasakan kolaborasi, engineering workflow, ownership, code review, deployment, mentoring, dan kontribusi seperti di project nyata. YYZU hadir sebagai talent bridge untuk proses pertumbuhan itu."
    note="Fokus YYZU adalah pengembangan engineer melalui engineering culture, collaborative learning, project collaboration, dan industry-oriented growth."
  />

  <section class="bg-[#f7f9fb] py-16 sm:py-20">
    <div class="mx-auto grid max-w-7xl gap-10 px-5 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:px-8">
      <Section
        eyebrow="The Gap"
        title="Masalahnya bukan kurang belajar, tetapi kurang konteks praktik engineering."
        description="Academic learning dan self-learning memberi fondasi penting. Namun untuk siap masuk lingkungan software engineering, talenta juga perlu berlatih bekerja dengan orang lain, mengelola task, menerima review, memahami system design, dan menjaga kualitas delivery."
      />
      <div class="grid gap-5">
        {whyYYZU.map((item) => <InfoCard {...item} />)}
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-16 text-white sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <Section
        eyebrow="Bridge Direction"
        title="YYZU menjadi jembatan antara campus, community, dan industry."
        description="Yang dibangun bukan sekadar tempat belajar bareng, tetapi lingkungan pengembangan talenta IT yang menumbuhkan kebiasaan kerja engineering secara bertahap."
        align="center"
        tone="dark"
      />
      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        {
          bridgeCards.map((item) => (
            <article class="rounded-lg border border-white/12 bg-white/[0.06] p-7">
              <h3 class="text-xl font-bold text-white">{item.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-300">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto grid max-w-7xl gap-5 px-5 sm:px-6 lg:grid-cols-2 lg:px-8">
      {
        visionMission.map((item) => (
          <article class="rounded-lg border border-slate-200 bg-slate-50 p-8">
            <p class="text-sm font-bold uppercase tracking-[0.22em] text-[#006A67]">
              {item.title}
            </p>
            <p class="mt-5 text-xl font-bold leading-8 text-slate-950">
              {item.description}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="bg-[#f7f9fb] py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <Section
        eyebrow="Long-Term Direction"
        title="Membangun ekosistem talent growth yang kredibel dan industry-relevant."
        description="Arah jangka panjang YYZU adalah membangun lingkungan yang menghubungkan talenta, kampus, mentor, komunitas teknologi Indonesia, dan industri melalui kontribusi yang bisa dilihat dan proses yang bisa dipercaya."
        align="center"
      />
      <div class="mt-12 grid gap-4 md:grid-cols-3">
        {
          [
            "Ruang latihan engineering workflow",
            "Project-based growth environment",
            "Jembatan kolaborasi kampus dan industri",
          ].map((item) => (
            <div class="rounded-lg border border-slate-200 bg-white p-6 text-center shadow-sm">
              <p class="text-base font-bold text-slate-950">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    title="Arah YYZU sederhana: tumbuh lewat proses engineering yang nyata."
    description="Jika arah ini relevan, langkah berikutnya adalah memahami engineering culture dan mindset yang membentuk cara YYZU bekerja."
    primaryLabel="Lihat Culture"
    primaryHref="/culture/"
    secondaryLabel="Join YYZU"
    secondaryHref="/join/"
  />
</BaseLayout>
