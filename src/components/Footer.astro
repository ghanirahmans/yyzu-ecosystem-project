---
import { navigation } from "../data/site";
---

<footer class="border-t border-slate-200 bg-slate-950 text-white">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 py-12 sm:px-6 md:grid-cols-[1.1fr_0.9fr_0.9fr] lg:px-8">
    <div>
      <div class="flex items-center gap-3">
        <span class="flex size-10 items-center justify-center rounded-lg bg-white">
          <img
            src="/yyz-project-logo_ft.svg"
            alt=""
            width="26"
            height="26"
            decoding="async"
          />
        </span>
        <span class="font-bold tracking-[0.18em]">YYZU</span>
      </div>
      <p class="mt-5 max-w-md text-sm leading-7 text-slate-300">
        Collaborative technology ecosystem dan talent bridge yang membantu
        kampus, talenta teknologi, komunitas, mentor, dan industri tumbuh lewat
        learning, project, mentoring, workflow industri, dan kolaborasi nyata.
      </p>
    </div>
    <div>
      <h3 class="text-sm font-bold uppercase tracking-[0.18em] text-slate-400">
        Navigation
      </h3>
      <div class="mt-4 grid gap-3">
        {
          navigation.map((item) => (
            <a
              href={item.href}
              class="text-sm text-slate-300 transition hover:text-white"
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
    <div>
      <h3 class="text-sm font-bold uppercase tracking-[0.18em] text-slate-400">
        Contact
      </h3>
      <div class="mt-4 grid gap-3 text-sm text-slate-300">
        <span>
          Email: {" "}
          <a href="mailto:yyzucommunity@gmail.com" class="hover:text-white"> 
            yyzucommunity@gmail.com
        </a>
        </span>
        
        <span>LinkedIn: coming soon</span>
        <span>
          Instagram:{" "}
          <a
            href="https://instagram.com/yyzucommunity"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white"
          >
            yyzucommunity
          </a>
        </span>
      </div>
    </div>
  </div>
  <div class="border-t border-white/10 px-5 py-5 text-center text-xs text-slate-400">
    Copyright 2026 YYZU. All rights reserved.
  </div>
</footer>
