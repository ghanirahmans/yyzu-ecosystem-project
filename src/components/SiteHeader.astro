---
import { navigation } from "../data/site";
---

<header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/88 backdrop-blur-xl">
  <nav
    aria-label="Navigasi utama"
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-5 sm:px-6 lg:px-8"
  >
    <a
      href="#beranda"
      class="flex items-center gap-3 text-slate-950"
      aria-label="YYZU beranda"
      data-mobile-menu-link
    >
      <span class="flex size-9 items-center justify-center rounded-lg bg-white shadow-sm ring-1 ring-slate-200">
        <img
          src="/yyz-project-logo_ft.svg"
          alt=""
          width="24"
          height="24"
          decoding="async"
        />
      </span>
      <span class="text-base font-bold tracking-[0.18em]">YYZU</span>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      {
        navigation.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-slate-600 transition hover:text-[#0015A5]"
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <a
      href="#kontak"
      class="hidden rounded-full bg-[#0015A5] px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-[#00118a] md:inline-flex"
    >
      Hubungi
    </a>

    <button
      type="button"
      class="inline-flex size-10 items-center justify-center rounded-lg border border-slate-200 text-slate-800 transition hover:border-slate-300 hover:bg-slate-50 md:hidden"
      aria-label="Buka menu navigasi"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-mobile-menu-button
    >
      <span class="sr-only">Menu</span>
      <span class="relative block h-4 w-5">
        <span
          class="absolute left-0 top-0 h-0.5 w-5 rounded bg-current transition"
          data-menu-line="top"
        ></span>
        <span
          class="absolute left-0 top-[7px] h-0.5 w-5 rounded bg-current transition"
          data-menu-line="middle"
        ></span>
        <span
          class="absolute bottom-0 left-0 h-0.5 w-5 rounded bg-current transition"
          data-menu-line="bottom"
        ></span>
      </span>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-slate-200 bg-white px-5 py-4 shadow-sm md:hidden"
  >
    <div class="mx-auto flex max-w-7xl flex-col gap-1">
      {
        navigation.map((item) => (
          <a
            href={item.href}
            class="rounded-lg px-3 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 hover:text-[#0015A5]"
            data-mobile-menu-link
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="#kontak"
        class="mt-2 rounded-lg bg-[#0015A5] px-3 py-3 text-center text-sm font-semibold text-white"
        data-mobile-menu-link
      >
        Hubungi YYZU
      </a>
    </div>
  </div>
</header>

<script>
  const button = document.querySelector("[data-mobile-menu-button]");
  const menu = document.querySelector("#mobile-menu");
  const menuLinks = document.querySelectorAll("[data-mobile-menu-link]");
  const topLine = document.querySelector('[data-menu-line="top"]');
  const middleLine = document.querySelector('[data-menu-line="middle"]');
  const bottomLine = document.querySelector('[data-menu-line="bottom"]');

  const setMenu = (isOpen: boolean) => {
    button?.setAttribute("aria-expanded", String(isOpen));
    menu?.classList.toggle("hidden", !isOpen);
    topLine?.classList.toggle("translate-y-[7px]", isOpen);
    topLine?.classList.toggle("rotate-45", isOpen);
    middleLine?.classList.toggle("opacity-0", isOpen);
    bottomLine?.classList.toggle("-translate-y-[7px]", isOpen);
    bottomLine?.classList.toggle("-rotate-45", isOpen);
  };

  button?.addEventListener("click", () => {
    setMenu(button.getAttribute("aria-expanded") !== "true");
  });

  menuLinks.forEach((link) => {
    link.addEventListener("click", () => setMenu(false));
  });
</script>
